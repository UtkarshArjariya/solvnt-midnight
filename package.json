{
  "name": "solvnt-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm zk:sync",
    "dev": "next dev --port 3000",
    "prebuild": "pnpm zk:sync",
    "build": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "smoke": "tsx scripts/smoke.mts",
    "smoke:ada": "tsx scripts/smoke-ada.mts",
    "smoke:all": "pnpm smoke && pnpm smoke:ada",
    "contracts:compile": "compact compile +0.31.0 contracts/issuer-registry.compact build/contracts/issuer-registry && compact compile +0.31.0 contracts/range-proof.compact build/contracts/range-proof",
    "zk:sync": "tsx scripts/copy-zk-assets.mts",
    "deploy": "tsx scripts/deploy.mts",
    "clean": "rm -rf .next out public/contracts"
  },
  "dependencies": {
    "@midnight-ntwrk/dapp-connector-api": "^4.0.1",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.4",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.4",
    "@midnight-ntwrk/midnight-js-types": "^4.0.4",
    "@midnight-ntwrk/midnight-js-utils": "^4.0.4",
    "@noble/ed25519": "2.1.0",
    "@noble/hashes": "1.5.0",
    "lucide-react": "0.460.0",
    "motion": "11.11.17",
    "next": "14.2.18",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "semver": "^7.8.0",
    "zod": "3.23.8",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.1",
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.4",
    "@midnight-ntwrk/platform-js": "^2.2.4",
    "@midnight-ntwrk/wallet": "^5.0.0",
    "@types/node": "22.9.0",
    "@types/qrcode": "1.5.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/semver": "^7.7.1",
    "autoprefixer": "10.4.20",
    "effect": "^3.21.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15",
    "tsx": "^4.22.1",
    "typescript": "5.6.3"
  }
}
