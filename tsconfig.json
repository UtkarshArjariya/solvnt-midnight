{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./src/*"] },
    "noEmit": true,
    "allowJs": false
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "contracts/**/*.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "notes", "docs", "scripts"]
}
