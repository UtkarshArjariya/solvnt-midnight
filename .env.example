NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Midnight network
# =============================================================================
#
# Active network. Valid: preprod | testnet | devnet | undeployed
NEXT_PUBLIC_MIDNIGHT_NETWORK=preprod

# Blockfrost-hosted Midnight infrastructure (preprod) — DISABLED.
# Probing the gateway with this key returned redirect loops to a 404 path
# (/api/v0/network -> /midnight/api/v4/v3/graphql/network -> 404). Likely
# the gateway is mid-rollout or this key isn't fully provisioned. Restore
# these overrides once the endpoint responds correctly; until then the
# defaults in src/lib/midnight/config.ts point at the official preprod
# indexer + node, which work without auth.
NEXT_PUBLIC_MIDNIGHT_BLOCKFROST_KEY=<YOUR_KEY_HERE>
# NEXT_PUBLIC_MIDNIGHT_INDEXER=https://midnight-preprod.blockfrost.io/api/v0
# NEXT_PUBLIC_MIDNIGHT_INDEXER_WS=wss://midnight-preprod.blockfrost.io/api/v0/ws
# NEXT_PUBLIC_MIDNIGHT_NODE=https://rpc.midnight-preprod.blockfrost.io

# Proof server. Empty = use the local Docker proofer on :6300. Set to
# https://lace-proof-pub.preprod.midnight.network when serving over HTTPS.
NEXT_PUBLIC_MIDNIGHT_PROOF_SERVER=

# =============================================================================
# Cardano (Blockfrost) — for the ADA snapshot issuer (lib/cardano.ts).
# These are SEPARATE project_ids from the Midnight one above. Get them free
# at https://blockfrost.io — pick "Cardano Preprod" / "Cardano Mainnet".
# =============================================================================
BLOCKFROST_PROJECT_ID_MAINNET=
BLOCKFROST_PROJECT_ID_PREPROD=
BLOCKFROST_PROJECT_ID_PREVIEW=
